{
  "name": "gizipp/isbn-toolkit",
  "description": "All-in-one ISBN toolkit for PHP. Validate, convert, and lookup book metadata.",
  "keywords": ["isbn", "isbn-10", "isbn-13", "ean-13", "book", "metadata", "laravel", "validation"],
  "homepage": "https://github.com/gizipp/isbn-toolkit-php",
  "license": "MIT",
  "authors": [
    {
      "name": "Gilang R. Aprianto",
      "email": "gilang@gizipp.com",
      "homepage": "https://gizipp.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0",
    "guzzlehttp/guzzle": "^7.0",
    "laravel/framework": "^10.0 || ^11.0"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Required for metadata lookup feature",
    "laravel/framework": "Required for Laravel validation rule"
  },
  "autoload": {
    "psr-4": {
      "Gizipp\\IsbnToolkit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Gizipp\\IsbnToolkit\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
